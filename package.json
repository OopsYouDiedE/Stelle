{
  "name": "stelle",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && vite build --config assets/renderer/client/vite.config.ts && tsc",
    "start": "node scripts/start_all.js runtime --built",
    "start:discord": "node dist/start.js discord",
    "start:live": "node scripts/start_all.js live --built",
    "start:runtime": "node scripts/start_all.js runtime --built",
    "start:kokoro": ".venv\\Scripts\\python.exe scripts\\kokoro_tts_server.py",
    "live:preflight": "tsx scripts/live_preflight.ts",
    "live:preflight:json": "tsx scripts/live_preflight.ts --json",
    "live:bilibili": "tsx scripts/bilibili_danmaku_bridge.ts",
    "live:export-logs": "tsx scripts/live_export_logs.ts",
    "live:episode-summary": "tsx scripts/live_episode_summary.ts",
    "live:terminal": "npm run build && npm run live:preflight && node scripts/start_all.js live --built --bilibili",
    "live:terminal:dry": "npm run build && npm run live:preflight && node scripts/start_all.js live --built --bilibili --bilibili-dry-run",
    "dev:live": "node scripts/start_all.js live --watch",
    "dev:live:terminal": "node scripts/start_all.js live --watch --bilibili",
    "dev:discord": "tsx watch src/start.ts discord",
    "dev": "node scripts/start_all.js runtime --watch",
    "dev:runtime": "node scripts/start_all.js runtime --watch",
    "test": "vitest run",
    "test:eval": "vitest run -c vitest.eval.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "mime": "^4.1.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^8.0.9",
    "yaml": "^2.7.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "gh-pages": "^6.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
