DISCORD_TOKEN=
DISCORD_TEST_CHANNEL_ID=
DISCORD_OWNER_USER_ID=
DISCORD_AMBIENT_CHANNEL_IDS=

GEMINI_API_KEY=
GOOGLE_API_KEY=
AISTUDIO_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
STELLE_PRIMARY_MODEL=gemma-4-31b-it
STELLE_SECONDARY_MODEL=gemma-4-31b-it
STELLE_TTS_MODEL=gemini-3.1-flash-tts-preview
STELLE_TTS_PROVIDER=kokoro

# Kokoro local Python TTS server
KOKORO_TTS_BASE_URL=http://127.0.0.1:8880
KOKORO_TTS_ENDPOINT_PATH=/v1/audio/speech
KOKORO_TTS_PLAY_ENDPOINT_PATH=/v1/audio/speech/play
KOKORO_TTS_MODEL=kokoro
KOKORO_TTS_VOICE=zf_xiaobei
KOKORO_TTS_LANGUAGE=z
KOKORO_TTS_API_KEY=
KOKORO_TTS_RESPONSE_FORMAT=wav
KOKORO_TTS_STREAM_RESPONSE_FORMAT=wav
KOKORO_PYTHON=.venv\Scripts\python.exe
KOKORO_SERVER_SCRIPT=scripts\kokoro_tts_server.py
KOKORO_AUTO_START=true
KOKORO_START_TIMEOUT_MS=45000
KOKORO_PRELOAD=true
KOKORO_WARMUP_ENABLED=true
KOKORO_WARMUP_TEXT=你好，中文语音预热完成。
KOKORO_WARMUP_TIMEOUT_MS=90000
KOKORO_AUDIO_DEVICE=
KOKORO_AUDIO_BLOCKSIZE=0

# DashScope / Aliyun Bailian Qwen-TTS
# Set STELLE_TTS_PROVIDER=dashscope to use these for live speech.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_HTTP_API_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_TTS_ENDPOINT_PATH=/services/aigc/multimodal-generation/generation
QWEN_TTS_MODEL=qwen3-tts-instruct-flash
QWEN_TTS_LIVE_MODEL=qwen3-tts-instruct-flash
QWEN_TTS_VOICE=Cherry
QWEN_TTS_LANGUAGE_TYPE=Chinese
QWEN_TTS_INSTRUCTIONS=语气活泼、亲切，像虚拟主播直播间即时回应。语速中等偏快，句尾自然，避免夸张播音腔。
QWEN_TTS_OPTIMIZE_INSTRUCTIONS=true
QWEN_TTS_STREAMING=false
QWEN_TTS_SAMPLE_RATE=24000

# Search providers
SERPAPI_API_KEY=
SERPAPI_ENGINE=google
SERPAPI_HL=zh-cn
SERPAPI_GL=cn
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# Discord direct-reply TTS artifact generation
DISCORD_TTS_ENABLED=false

# Live renderer / Live2D / OBS
BILIBILI_LIVE_ENABLED=false
BILIBILI_ROOM_ID=
# Optional: helps Bilibili danmaku API pass risk control. Keep local and never commit.
BILIBILI_COOKIE=

# Twitch IRC chat bridge. Token format is oauth:...
TWITCH_LIVE_ENABLED=false
TWITCH_CHANNEL=
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_TRACK_JOINS=false

# YouTube Live Streaming API chat bridge.
# Prefer YOUTUBE_LIVE_CHAT_ID; otherwise set YOUTUBE_VIDEO_ID so Stelle can resolve activeLiveChatId.
YOUTUBE_LIVE_ENABLED=false
YOUTUBE_LIVE_CHAT_ID=
YOUTUBE_VIDEO_ID=
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_TOKEN=
YOUTUBE_FORWARD_HISTORY=false

# TikTok has no native public live-comment API; use either a relay WebSocket
# or install/configure tiktok-live-connector and set TIKTOK_PROVIDER=tiktok-live-connector.
TIKTOK_LIVE_ENABLED=false
TIKTOK_PROVIDER=websocket
TIKTOK_USERNAME=
TIKTOK_LIVE_WS_URL=
TIKTOK_API_KEY=

LIVE_THANKS_ENABLED=true
LIVE_IDLE_ENABLED=true
LIVE_IDLE_MIN_QUIET_SECONDS=90
LIVE_IDLE_COOLDOWN_SECONDS=120
LIVE_SCHEDULE_ENABLED=false
LIVE2D_RESOURCES_ROOT=assets/live2d/public/Resources
LIVE2D_PUBLIC_ROOT=assets/live2d/public
LIVE2D_DEFAULT_MODEL=Hiyori_pro
LIVE_RENDERER_HOST=127.0.0.1
LIVE_RENDERER_PORT=8787
LIVE_RENDERER_URL=http://127.0.0.1:8787
LIVE_SPEECH_TICK_MS=4500
LIVE_SPEECH_QUEUE_LIMIT=3
LIVE_TTS_ENABLED=true
LIVE_TTS_OUTPUT=browser
LIVE_TTS_STREAMING=true
LIVE_TTS_TIMEOUT_MS=15000
LIVE_TTS_CACHE_TTL_MS=600000
LIVE_TTS_CACHE_MAX_ENTRIES=80

# OBS WebSocket v5
OBS_CONTROL_ENABLED=false
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=

# Device action drivers
# Browser control requires Chrome/Edge started with --remote-debugging-port=9222.
BROWSER_ENABLED=false
BROWSER_CDP_URL=http://127.0.0.1:9222
DESKTOP_INPUT_ENABLED=false
ANDROID_DEVICE_ENABLED=false

# Read-only live scene awareness. Disabled by default.
SCENE_OBSERVATION_ENABLED=false
ANDROID_ADB_PATH=adb

# Runtime convenience
STELLE_OPEN_DEBUG_WINDOW=false
STELLE_DEBUG_ENABLED=false
STELLE_DEBUG_REQUIRE_TOKEN=true
STELLE_DEBUG_TOKEN=
STELLE_DEBUG_ALLOW_EXTERNAL_WRITE=false
STELLE_CONTROL_REQUIRE_TOKEN=true
STELLE_CONTROL_TOKEN=
