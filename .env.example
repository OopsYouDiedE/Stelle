DISCORD_TOKEN=
GEMINI_API_KEY=
GOOGLE_API_KEY=
AISTUDIO_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
STELLE_PRIMARY_MODEL=gemini-3.1-flash-lite-preview
STELLE_SECONDARY_MODEL=gemini-3.1-flash-lite-preview

# Kokoro local Python TTS. Expected default API shape is OpenAI-compatible:
# POST /v1/audio/speech { model, input, voice, response_format, stream? } -> audio bytes.
KOKORO_TTS_BASE_URL=http://127.0.0.1:8880
KOKORO_TTS_ENDPOINT_PATH=/v1/audio/speech
KOKORO_TTS_PLAY_ENDPOINT_PATH=/v1/audio/speech/play
KOKORO_TTS_MODEL=kokoro
KOKORO_TTS_VOICE=zf_xiaobei
KOKORO_TTS_LANGUAGE=z
KOKORO_TTS_API_KEY=
KOKORO_TTS_RESPONSE_FORMAT=wav
# Live renderer asks Kokoro for streaming audio by default. Use mp3 here if your
# Kokoro-compatible service streams MP3; the bundled local server streams WAV PCM.
KOKORO_TTS_STREAM_RESPONSE_FORMAT=wav
KOKORO_PYTHON=.venv\Scripts\python.exe
KOKORO_SERVER_SCRIPT=scripts\kokoro_tts_server.py
# The main runtime starts the local Python Kokoro server by default.
KOKORO_AUTO_START=true
KOKORO_START_TIMEOUT_MS=45000
KOKORO_PRELOAD=true
KOKORO_WARMUP_ENABLED=true
KOKORO_WARMUP_TEXT=你好，直播语音预热完成。
KOKORO_WARMUP_TIMEOUT_MS=90000
# Python audio output. For OBS, install VB-CABLE and set this to CABLE Input;
# then add CABLE Output as an Audio Input Capture source in OBS.
KOKORO_AUDIO_DEVICE=CABLE Input
KOKORO_AUDIO_BLOCKSIZE=0

SERPAPI_API_KEY=
SERPAPI_ENGINE=google
SERPAPI_HL=zh-cn
SERPAPI_GL=cn
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# Browser Cursor defaults to a visible persistent Chromium window.
# Set BROWSER_HEADLESS=true only for CI or non-interactive tests.
BROWSER_HEADLESS=false
# Optional. Defaults to artifacts/browser/profile.
BROWSER_PROFILE_DIR=
# playwright = managed persistent Chromium. cdp = connect to your real Chrome/Edge
# launched with --remote-debugging-port.
BROWSER_MODE=playwright
BROWSER_CDP_URL=http://127.0.0.1:9222

# When true, Discord-attached Core Mind also asks Kokoro TTS to synthesize each direct reply.
# This creates local artifacts under artifacts/tts; Discord text reply still uses Discord tools.
DISCORD_TTS_ENABLED=false

# Live Cursor / OBS
# Live2D resources are copied into this project; no runtime dependency on ai-live2d-go.
LIVE2D_RESOURCES_ROOT=assets/live2d/public/Resources
LIVE2D_PUBLIC_ROOT=assets/live2d/public
LIVE2D_DEFAULT_MODEL=Hiyori_pro
LIVE_RENDERER_HOST=127.0.0.1
LIVE_RENDERER_PORT=8787
LIVE_RENDERER_URL=http://127.0.0.1:8787
# How often Discord-attached Core ticks the queued live speech buffer.
LIVE_SPEECH_TICK_MS=4500
# When true, live commands also call Kokoro TTS and OBS browser source plays the generated audio.
LIVE_TTS_ENABLED=true
# python-device = Kokoro Python service plays audio to KOKORO_AUDIO_DEVICE.
# browser = OBS browser source plays streamed audio.
# artifact = write wav artifacts and let the browser play those files.
LIVE_TTS_OUTPUT=python-device
# Defaults to true. Set false to fall back to writing artifacts/tts/*.wav before playback.
LIVE_TTS_STREAMING=true

# OBS WebSocket v5. Enable only when OBS WebSocket is running.
OBS_CONTROL_ENABLED=false
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=
