DISCORD_TOKEN=
OPENAI_API_KEY=
# If OPENAI_API_KEY is not set, you can use OPENROUTER_API_KEY or GEMINI_API_KEY.
OPENROUTER_API_KEY=
GEMINI_API_KEY=
SERPAPI_API_KEY=
SERPAPI_ENGINE=google
SERPAPI_HL=zh-cn
SERPAPI_GL=cn
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# Browser Cursor defaults to a visible persistent Chromium window.
# Set BROWSER_HEADLESS=true only for CI or non-interactive tests.
BROWSER_HEADLESS=false
# Optional. Defaults to artifacts/browser/profile.
BROWSER_PROFILE_DIR=
# playwright = managed persistent Chromium. cdp = connect to your real Chrome/Edge
# launched with --remote-debugging-port.
BROWSER_MODE=playwright
BROWSER_CDP_URL=http://127.0.0.1:9222

# Audio Cursor
# STT defaults to OpenAI gpt-4o-mini-transcribe.
AUDIO_STT_MODEL=gpt-4o-mini-transcribe

# TTS is intended for a local Kokoro-82M/OpenAI-compatible speech endpoint.
# Example endpoint shape: POST ${KOKORO_TTS_BASE_URL}/v1/audio/speech
KOKORO_TTS_BASE_URL=http://127.0.0.1:8880
KOKORO_TTS_MODEL=kokoro
KOKORO_TTS_VOICE=af_heart
KOKORO_TTS_API_KEY=
