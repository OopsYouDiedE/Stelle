DISCORD_TOKEN=
DISCORD_TEST_CHANNEL_ID=
DISCORD_OWNER_USER_ID=

GEMINI_API_KEY=
GOOGLE_API_KEY=
AISTUDIO_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
STELLE_PRIMARY_MODEL=gemma-4-31b-it
STELLE_SECONDARY_MODEL=gemma-4-31b-it
STELLE_TTS_MODEL=gemini-3.1-flash-tts-preview

# Kokoro local Python TTS server
KOKORO_TTS_BASE_URL=http://127.0.0.1:8880
KOKORO_TTS_ENDPOINT_PATH=/v1/audio/speech
KOKORO_TTS_PLAY_ENDPOINT_PATH=/v1/audio/speech/play
KOKORO_TTS_MODEL=kokoro
KOKORO_TTS_VOICE=zf_xiaobei
KOKORO_TTS_LANGUAGE=z
KOKORO_TTS_API_KEY=
KOKORO_TTS_RESPONSE_FORMAT=wav
KOKORO_TTS_STREAM_RESPONSE_FORMAT=wav
KOKORO_PYTHON=.venv\Scripts\python.exe
KOKORO_SERVER_SCRIPT=scripts\kokoro_tts_server.py
KOKORO_AUTO_START=true
KOKORO_START_TIMEOUT_MS=45000
KOKORO_PRELOAD=true
KOKORO_WARMUP_ENABLED=true
KOKORO_WARMUP_TEXT=你好，中文语音预热完成。
KOKORO_WARMUP_TIMEOUT_MS=90000
KOKORO_AUDIO_DEVICE=
KOKORO_AUDIO_BLOCKSIZE=0

# Search providers
SERPAPI_API_KEY=
SERPAPI_ENGINE=google
SERPAPI_HL=zh-cn
SERPAPI_GL=cn
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# Discord direct-reply TTS artifact generation
DISCORD_TTS_ENABLED=false

# Live renderer / Live2D / OBS
LIVE2D_RESOURCES_ROOT=assets/live2d/public/Resources
LIVE2D_PUBLIC_ROOT=assets/live2d/public
LIVE2D_DEFAULT_MODEL=Hiyori_pro
LIVE_RENDERER_HOST=127.0.0.1
LIVE_RENDERER_PORT=8787
LIVE_RENDERER_URL=http://127.0.0.1:8787
LIVE_SPEECH_TICK_MS=4500
LIVE_TTS_ENABLED=true
LIVE_TTS_OUTPUT=browser
LIVE_TTS_STREAMING=true

# OBS WebSocket v5
OBS_CONTROL_ENABLED=false
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=

# Runtime convenience
STELLE_OPEN_DEBUG_WINDOW=true
